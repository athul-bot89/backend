# ============================================
# AI PROVIDER CONFIGURATION
# ============================================

# Choose AI Provider: set to "true" for Azure OpenAI, "false" for standard OpenAI
USE_AZURE_OPENAI=false

# --------------------------------------------
# Standard OpenAI Configuration (if USE_AZURE_OPENAI=false)
# --------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
# Optional: Specify model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# --------------------------------------------
# Azure OpenAI Configuration (if USE_AZURE_OPENAI=true)
# --------------------------------------------
# AZURE_OPENAI_API_KEY=your-azure-api-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite (default) - no changes needed for local development
DATABASE_URL=sqlite:///./teaching_assistant.db

# PostgreSQL (production example)
# DATABASE_URL=postgresql://user:password@localhost:5432/teaching_assistant

# ============================================
# FILE STORAGE CONFIGURATION
# ============================================
# Directory for uploaded PDF files
UPLOAD_DIR=uploads

# Directory for generated chapter PDFs
CHAPTERS_DIR=chapters

# Maximum file upload size in bytes (50MB default)
MAX_UPLOAD_SIZE=52428800

# ============================================
# API SERVER CONFIGURATION
# ============================================
# Host to bind the server to (0.0.0.0 allows external connections)
API_HOST=0.0.0.0

# Port to run the server on
API_PORT=8000

# Number of worker processes (for production only, not used with --reload)
# WORKERS=4

# ============================================
# SECURITY & CORS (Uncomment for production)
# ============================================
# Allowed CORS origins (comma-separated or JSON array)
# CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]

# Secret key for JWT tokens (generate a strong random string)
# SECRET_KEY=your-secret-key-here-use-secrets-module-to-generate

# JWT algorithm
# ALGORITHM=HS256

# Token expiration time in minutes
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# LOGGING CONFIGURATION (Optional)
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Log file path (if not set, logs to console only)
# LOG_FILE=logs/app.log

# ============================================
# RATE LIMITING (Optional for production)
# ============================================
# Maximum requests per minute per IP
# RATE_LIMIT_PER_MINUTE=60

# ============================================
# MONITORING (Optional)
# ============================================
# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================
# FEATURES FLAGS (Optional)
# ============================================
# Enable/disable specific features
# ENABLE_VISION_API=true
# ENABLE_SCHEDULE_GENERATION=true
# ENABLE_STUDY_PLAN=true